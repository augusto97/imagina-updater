{
    "name": "imagina/license-extension",
    "description": "Premium licensing layer for Imagina Updater Server (auto-injects protection into premium plugin ZIPs).",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "classmap": [
            "includes/"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "support": {
        "source": "https://github.com/augusto97/imagina-updater"
    }
}
